# ---------- LLM：默认 DeepSeek（OpenAI 兼容），勿与智谱密钥混用 ----------
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
# 可选：未设置 LLM_MODEL 时用 DEEPSEEK_MODEL 作为默认模型名
# DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=

# 智谱 GLM
# LLM_PROVIDER=zhipu
# LLM_MODEL=glm-4-flash
# ZHIPU_API_KEY=

# -----------------------------
# PostgreSQL (Azure Database for PostgreSQL)
# -----------------------------
DB_ENABLED=true
DB_HOST=document.postgres.database.azure.com
DB_PORT=5432
DB_NAME=postgres
# Azure PostgreSQL 用户名通常为: <username>@document
DB_USER=your_username@document
DB_PASSWORD=your_password
DB_SSLMODE=require

# 也可直接使用连接串（二选一，优先级更高）
# DATABASE_URL=postgresql://your_username%40document:your_password@document.postgres.database.azure.com:5432/postgres?sslmode=require

# -----------------------------
# 阿里云 OSS（可选，勿提交密钥）
# -----------------------------
# STORAGE_PROVIDER=aliyun_oss
# STORAGE_ENABLED=true
# OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=your-bucket-name
# OSS_PREFIX=sessions