# 复制为 .env 后填写：copy .env.example .env

# ---------- LLM：默认 DeepSeek（OpenAI 兼容） ----------
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=

# 智谱 GLM（二选一，取消注释并填写密钥）
# LLM_PROVIDER=zhipu
# LLM_MODEL=glm-4-flash
# ZHIPU_API_KEY=

# ---------- 认证 ----------
# 登录 JWT 签名密钥，本地可随意一串；生产环境请改为足够长的随机字符串
AUTH_SECRET_KEY=change-me-in-production

# ---------- MySQL（XAMPP 本地，推荐） ----------
DB_ENABLED=true
DATABASE_URL=mysql://root:@localhost:3306/doc_intel

# 也可分段配置（未设置 DATABASE_URL 时生效）：
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=doc_intel
# DB_USER=root
# DB_PASSWORD=

# ---------- 阿里云 OSS（可选，默认本地存储，无需配置） ----------
# STORAGE_PROVIDER=aliyun_oss
# STORAGE_ENABLED=true
# OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=your-bucket-name
# OSS_PREFIX=sessions
